# ── ARGUS / Cíclope — variáveis de ambiente (exemplo) ──
# Copie para .env e preencha. A chave também pode ser informada em runtime na aba Configurações da UI.

# Provider e modelo padrão (litellm model ids)
ARGUS_LLM_PROVIDER=gemini
ARGUS_LLM_MODEL=gemini/gemini-2.5-flash
# alternativa rápida/barata: gemini/gemini-2.5-flash-lite
ARGUS_LLM_TEMPERATURE=0.2

# Chaves de API (preencha apenas a(s) que for usar)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS — origem do frontend em dev
ARGUS_CORS_ORIGINS=http://localhost:5173

# Timeout da chamada ao LLM (s) — abaixo do limite ~100s do Cloudflare
ARGUS_LLM_TIMEOUT=90

# Modo mock (1 = não chama LLM real; retorna ThreatModel canônico p/ testes/demo offline)
ARGUS_LLM_MOCK=0

# ─────────────────────────────────────────────────────────────────────────────
# Pipeline ARGUS (E1–E4). Só roda em ambiente de ML (torch/OCR) — NÃO no backend
# de produção 3.14. O Cíclope (acima) independe deste bloco.
# ─────────────────────────────────────────────────────────────────────────────

# E1 — Detector (escolha UMA forma): repo do HF Hub OU caminho local do best.pt
ARGUS_DETECTOR_HF=zagari/argus-detector
# ARGUS_DETECTOR_WEIGHTS=/caminho/para/best.pt
ARGUS_DETECTOR_FILE=best.pt          # nome do arquivo no repo HF
ARGUS_DETECTOR_CONF=0.25             # confiança mínima da detecção
ARGUS_DETECTOR_IMGSZ=1280            # tamanho de inferência

# E2 — OCR (caminho por rótulo)
ARGUS_OCR_ENGINE=auto                # auto | paddle | easyocr
ARGUS_OCR_GPU=                       # vazio = autodetecta CUDA; 1 força GPU; 0 força CPU
ARGUS_OCR_LANGS=en,pt

# E2 — Fusão ícone+rótulo
ARGUS_FUSION_POLICY=label_wins       # label_wins | low_conf
ARGUS_FUSION_CONF=0.6                # usado quando policy=low_conf
ARGUS_FUSION_MAXDIST=0.06            # distância máx. (norm.) texto↔componente

# E2 — Cross-check de classificação via VLM (corrige incertos + propõe faltantes)
ARGUS_CROSSCHECK=1                   # 0 desliga
ARGUS_CROSSCHECK_CONF=0.75           # só corrige componentes com conf visual abaixo disto
ARGUS_CROSSCHECK_PROPOSE=1           # propor componentes/fronteiras que faltaram
ARGUS_CROSSCHECK_DEDUP=0.07          # dedup por distância entre centros

# Taxonomia (opcional) — sobrescreve o caminho do mapeamento.yaml
# ARGUS_MAPEAMENTO=/caminho/para/mapeamento.yaml
