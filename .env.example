# ── ARGUS / Cíclope — variáveis de ambiente (exemplo) ──
# Copie para .env e preencha. As chaves também podem ser informadas em runtime na aba Configurações da UI.

# Porta do host onde o app é publicado (SÓ em 127.0.0.1; aponte seu NGINX para http://127.0.0.1:ESTA_PORTA).
APP_PORT=8090

# ─────────────────────────────────────────────────────────────────────────────
# LLM GERADOR (Cíclope e ARGUS) — provider e modelo padrão (litellm model ids)
# ─────────────────────────────────────────────────────────────────────────────
ARGUS_LLM_PROVIDER=gemini
ARGUS_LLM_MODEL=gemini/gemini-2.5-flash
# alternativa rápida/barata: gemini/gemini-2.5-flash-lite
ARGUS_LLM_TEMPERATURE=0.2
ARGUS_LLM_TIMEOUT=90                  # timeout da chamada (s) — abaixo do limite ~100s do Cloudflare
ARGUS_LLM_MOCK=0                      # 1 = não chama LLM real; retorna ThreatModel canônico (testes/demo)

# Chaves de API (preencha apenas a(s) que for usar)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS — origem do frontend (dev: http://localhost:5173; prod: seu subdomínio https)
ARGUS_CORS_ORIGINS=http://localhost:5173

# Exibição de custo na UI — custo (US$) do litellm convertido para R$. Editáveis em runtime na UI.
ARGUS_USD_BRL_RATE=6.0               # cotação R$/US$
ARGUS_COST_FACTOR=1.0               # calibração: spread de câmbio + IOF + imprecisão da tabela; 1.0 = sem ajuste

# ─────────────────────────────────────────────────────────────────────────────
# Pipeline ARGUS (E1–E6). Só roda em ambiente de ML (torch/OCR) — NÃO no backend
# de produção 3.14. Use o venv de ML dedicado (.venv-ml, Python 3.13). O Cíclope independe deste bloco.
# ─────────────────────────────────────────────────────────────────────────────

# E1 — Detector (escolha UMA forma): repo do HF Hub OU caminho local do best.pt
ARGUS_DETECTOR_HF=zagari/argus-detector
# ARGUS_DETECTOR_WEIGHTS=/caminho/para/best.pt
ARGUS_DETECTOR_FILE=best.pt          # nome do arquivo no repo HF
ARGUS_DETECTOR_CONF=0.25             # confiança mínima da detecção
ARGUS_DETECTOR_IMGSZ=1280            # tamanho de inferência

# E2 — OCR (caminho por rótulo)
ARGUS_OCR_ENGINE=auto                # auto | paddle | easyocr
ARGUS_OCR_GPU=                       # vazio = autodetecta CUDA; 1 força GPU; 0 força CPU
ARGUS_OCR_LANGS=en,pt

# E2 — Fusão ícone+rótulo
ARGUS_FUSION_POLICY=label_wins       # label_wins | low_conf
ARGUS_FUSION_CONF=0.6                # usado quando policy=low_conf
ARGUS_FUSION_MAXDIST=0.06            # distância máx. (norm.) texto↔componente

# E2 — Cross-check de classificação via VLM (corrige incertos + propõe faltantes)
ARGUS_CROSSCHECK=1                   # 0 desliga
ARGUS_CROSSCHECK_CONF=0.75           # só corrige componentes com conf visual abaixo disto
ARGUS_CROSSCHECK_PROPOSE=1           # propor componentes/fronteiras que faltaram
ARGUS_CROSSCHECK_DEDUP=0.07          # dedup por distância entre centros

# E5 — RAG semântico (Chroma + embeddings locais). Opcional/gracioso: sem isto, cai no
# determinístico (enrich) e substring (busca do Explorer). Precisa das deps de ML (requirements-ml).
ARGUS_RAG=0                          # 1 = liga a busca semântica (índice constrói em background no startup)
ARGUS_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2   # modelo de embedding (PT↔EN); bge-m3 = mais pesado/preciso
# ARGUS_CHROMA_DIR=/data/chroma      # onde persiste o índice (em prod é volume; ver docker-compose)
# HF_HOME=/data/hf                   # cache do modelo de embedding (1ª execução baixa o modelo; em prod é volume)

# E5 — Backend do grafo de conhecimento (3.8). "local" (default) = LocalKG em memória (fonte de
# verdade, portátil). "neo4j" = grafo via Cypher (Graph-RAG + Neo4j Browser); se o driver
# (requirements-ml) ou a instância faltarem, cai automaticamente no LocalKG.
ARGUS_KG_BACKEND=local
NEO4J_URI=bolt://localhost:7687      # no docker é bolt://neo4j:7687 (ver docker-compose, profile full)
NEO4J_AUTH=neo4j/arguspass           # usuário/senha do Neo4j

# Taxonomia (opcional) — sobrescreve o caminho do mapeamento.yaml
# ARGUS_MAPEAMENTO=/caminho/para/mapeamento.yaml

# ─────────────────────────────────────────────────────────────────────────────
# Fase 5 — JUIZ (LLM-as-judge) via Vercel AI Gateway. Família DIFERENTE do gerador
# (anti self-preference): gerador = Gemini, juiz = Claude Opus. litellm tem provider
# nativo `vercel_ai_gateway/` (lê VERCEL_AI_GATEWAY_API_KEY; o código faz a ponte de JUDGE_API_KEY).
# ─────────────────────────────────────────────────────────────────────────────
JUDGE_API_KEY=                                              # chave do Vercel AI Gateway
JUDGE_MODEL=vercel_ai_gateway/anthropic/claude-opus-4.8     # ver slugs em https://ai-gateway.vercel.sh/v1/models
JUDGE_API_BASE=https://ai-gateway.vercel.sh/v1
JUDGE_TEMPERATURE=0                                         # determinístico (rubrica)
