# ── Produção: copie para ~/argus/.env no SERVIDOR e preencha. NÃO versionar. ──

# Porta do host onde o frontend (entrada web) é publicado, SÓ em 127.0.0.1.
# Escolha uma porta LIVRE no seu servidor; aponte seu NGINX para http://127.0.0.1:ESTA_PORTA.
APP_PORT=8090

# LLM (análise real — mock DESLIGADO)
ARGUS_LLM_PROVIDER=gemini
ARGUS_LLM_MODEL=gemini/gemini-2.5-flash
# alternativa rápida/barata: gemini/gemini-2.5-flash-lite
ARGUS_LLM_TEMPERATURE=0.2
ARGUS_LLM_MOCK=0

# Exibição de custo na UI (editável também na aba Configurações)
ARGUS_USD_BRL_RATE=6.0      # cotação R$/US$
ARGUS_COST_FACTOR=1.0       # calibração câmbio/IOF/tabela; meça (debitado real ÷ mostrado) e ajuste

# Chaves de API (preencha a(s) que for usar)
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# CORS: com o proxy do frontend as chamadas são same-origin (normalmente dispensável).
# Deixe o seu subdomínio por segurança.
ARGUS_CORS_ORIGINS=https://SEU-SUBDOMINIO.exemplo.com

# ─────────────────────────────────────────────────────────────────────────────
# Pipeline ARGUS (E1–E4). A imagem de produção é buildada em modo FULL pelo CI
# (INSTALL_ML=true → inclui torch CPU + ultralytics + OCR), então o ARGUS roda em
# produção. Estas variáveis ATIVAM e ajustam o pipeline. Ver argus/.env.example p/
# a lista completa de defaults.
# ─────────────────────────────────────────────────────────────────────────────

# E1 — detector (necessário p/ o ARGUS): repo do HF Hub OU caminho local do best.pt
ARGUS_DETECTOR_HF=zagari/argus-detector
# ARGUS_DETECTOR_WEIGHTS=/app/best.pt
ARGUS_OCR_GPU=0           # 0 = CPU (a latência do ARGUS é dominada pelo VLM, não pelo OCR)
ARGUS_CROSSCHECK=1        # cross-check/completude via VLM

# E5 — RAG semântico (Chroma + embeddings locais). Opt-in; índice/modelo no volume rag_data.
ARGUS_RAG=0              # 1 = liga (constrói o índice em background no 1º start; depois só carrega)
ARGUS_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2   # bge-m3 = mais pesado/preciso
# ARGUS_CHROMA_DIR e HF_HOME já vêm do docker-compose.prod.yml (volume)
